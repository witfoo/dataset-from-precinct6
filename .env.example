# =============================================================================
# Precinct6 Dataset Generator Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All values can also be set as environment variables directly.
# =============================================================================

# -----------------------------------------------------------------------------
# Cassandra Connection (required for 'extract' command)
# -----------------------------------------------------------------------------
# Your Precinct 6.x Cassandra cluster connection details.
# Find these in your Precinct deployment configuration.
CASSANDRA_HOST=
CASSANDRA_PORT=9042
CASSANDRA_USER=cassandra
CASSANDRA_PASSWORD=
CASSANDRA_SSL=true

# -----------------------------------------------------------------------------
# API Keys (optional - only needed for specific sanitization layers)
# -----------------------------------------------------------------------------
# Anthropic API key for Layer 4 (Claude AI contextual review).
# Get one at https://console.anthropic.com/
# Only required if using --claude flag during sanitization.
ANTHROPIC_API_KEY=

# HuggingFace token for uploading datasets to HuggingFace Hub.
# Get one at https://huggingface.co/settings/tokens
# Only required if uploading to HuggingFace.
HF_TOKEN=

# -----------------------------------------------------------------------------
# Data Directories (defaults to ./data/ subdirectories)
# -----------------------------------------------------------------------------
# DATA_DIR=./data
# RAW_DIR=./data/raw
# SANITIZED_DIR=./data/sanitized
# OUTPUT_DIR=./data/output

# -----------------------------------------------------------------------------
# Sanitization Settings
# -----------------------------------------------------------------------------
# Claude model for Layer 4 review (default: claude-sonnet-4-20250514)
# CLAUDE_REVIEW_MODEL=claude-sonnet-4-20250514

# ML/NER confidence thresholds
# ML_NER_CONFIDENCE_THRESHOLD=0.75
# PRESIDIO_SCORE_THRESHOLD=0.5

# Registry secret for deterministic IP mapping.
# Set this to make IP mappings reproducible across runs.
# If unset, a random key is generated each time (non-reproducible).
# REGISTRY_SECRET=your-secret-key-here

# -----------------------------------------------------------------------------
# Extraction Settings
# -----------------------------------------------------------------------------
# CASSANDRA_FETCH_SIZE=1000

# Lead rules catalog path (default: ./data/lead_rules_catalog.json)
# LEAD_RULES_CATALOG=./data/lead_rules_catalog.json
